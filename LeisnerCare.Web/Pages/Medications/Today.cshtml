@page
@model LeisnerCare.Web.Pages.Medications.TodayModel
@{
    ViewData["Title"] = "Dagens Medicin";
}

<h1><i class="bi bi-capsule me-2"></i>Dagens Medicin</h1>

@foreach (var med in Model.Medications)
{
    <div class="card mb-3 shadow-sm">
        <div class="card-body">
            <h4 class="card-title">@med.Name <span class="badge bg-primary">@med.Dosage</span></h4>
            <p class="text-muted"><i class="bi bi-clock me-1"></i>Frekvens: @med.Frequency</p>

            @if (med.IsTakenToday)
            {
                <div class="alert alert-success d-flex align-items-center">
                    <i class="bi bi-check-circle-fill me-2 fs-4"></i>
                    <div>
                        <strong>Taget!</strong> kl. @med.TakenAt?.ToString("HH:mm")
                    </div>
                </div>

                @if (med.Effectiveness.HasValue)
                {
                    <div class="alert alert-info">
                        <i class="bi bi-star-fill me-2"></i>Din vurdering: <strong>@med.Effectiveness.Value / 5</strong>
                    </div>
                }
                else
                {
                    <div class="mt-3">
                        <p class="fw-bold"><i class="bi bi-star me-2"></i>Hvor effektiv var medicinen?</p>
                        <form method="post">
                            <input type="hidden" name="handler" value="Rate" />
                            <input type="hidden" name="logId" value="@med.LogId" />
                            <div class="d-flex gap-2">
                                @for (int i = 1; i <= 5; i++)
                                {
                                    <button type="submit" name="effectiveness" value="@i"
                                            class="btn btn-outline-primary btn-lg fs-4 px-4">
                                        @i
                                    </button>
                                }
                            </div>
                        </form>
                    </div>
                }
            }
            else
            {
                <form method="post">
                    <input type="hidden" name="handler" value="Take" />
                    <input type="hidden" name="medicationId" value="@med.Id" />
                    <button type="submit" class="btn btn-success btn-lg">
                        <i class="bi bi-check-lg me-2"></i>Marker som taget
                    </button>
                </form>
            }
        </div>
    </div>
}