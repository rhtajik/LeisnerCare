@page
@model LeisnerCare.Web.Pages.Medications.CreateModel
@{
    ViewData["Title"] = "💊 Registrer Medicin";
}

<div class="row justify-content-center">
    <div class="col-md-8 col-lg-6">
        <div class="card shadow-lg border-0">
            <div class="card-header bg-success text-white text-center py-3">
                <h2 class="mb-0"><i class="bi bi-capsule me-2"></i>Registrer Medicin</h2>
            </div>
            <div class="card-body p-4">
                <form method="post">
                    <div asp-validation-summary="All" class="alert alert-danger" role="alert"></div>

                    <!-- Patient -->
                    <div class="mb-3">
                        <label asp-for="Input.PatientId" class="form-label fw-bold">
                            <i class="bi bi-person me-1 text-primary"></i>Patient
                        </label>
                        <select asp-for="Input.PatientId" asp-items="Model.Patients"
                                class="form-select form-select-lg">
                            <option value="">-- Vælg patient --</option>
                        </select>
                    </div>

                    <!-- Medicin navn -->
                    <div class="mb-3">
                        <label asp-for="Input.Name" class="form-label fw-bold">
                            <i class="bi bi-capsule me-1 text-success"></i>Medicin navn
                        </label>
                        <input asp-for="Input.Name" class="form-control form-control-lg"
                               placeholder="f.eks. Levodopa, Sinemet..." />
                    </div>

                    <!-- Dosis + Frekvens -->
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Input.Dosage" class="form-label fw-bold">
                                <i class="bi bi-droplet me-1 text-info"></i>Dosis
                            </label>
                            <input asp-for="Input.Dosage" class="form-control form-control-lg"
                                   placeholder="f.eks. 100 mg" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="Input.Frequency" class="form-label fw-bold">
                                <i class="bi bi-clock me-1 text-warning"></i>Frekvens
                            </label>
                            <input asp-for="Input.Frequency" class="form-control form-control-lg"
                                   placeholder="f.eks. 3 gange daglig" />
                        </div>
                    </div>

                    <!-- Tidspunkter -->
                    <div class="mb-3">
                        <label class="form-label fw-bold">
                            <i class="bi bi-alarm me-1 text-danger"></i>Tidspunkter
                        </label>
                        <div class="row g-2">
                            <div class="col-md-4">
                                <label asp-for="Input.TimeOfDay" class="form-label small text-muted">Tidspunkt 1</label>
                                <input asp-for="Input.TimeOfDay" type="time" class="form-control" />
                            </div>
                            <div class="col-md-4">
                                <label asp-for="Input.TimeOfDay2" class="form-label small text-muted">Tidspunkt 2 (valgfri)</label>
                                <input asp-for="Input.TimeOfDay2" type="time" class="form-control" />
                            </div>
                            <div class="col-md-4">
                                <label asp-for="Input.TimeOfDay3" class="form-label small text-muted">Tidspunkt 3 (valgfri)</label>
                                <input asp-for="Input.TimeOfDay3" type="time" class="form-control" />
                            </div>
                        </div>
                        <small class="text-muted">Angiv 1-3 tidspunkter afhængig af frekvens</small>
                    </div>

                    <!-- Knapper -->
                    <div class="d-grid gap-2 mt-4">
                        <button type="submit" class="btn btn-success btn-lg">
                            <i class="bi bi-check-lg me-2"></i>Gem Medicin
                        </button>
                        <a href="/Staff/MedicationOverview" class="btn btn-outline-secondary">
                            <i class="bi bi-arrow-left me-1"></i>Tilbage til oversigt
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>