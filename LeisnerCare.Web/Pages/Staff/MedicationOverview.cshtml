@page
@model LeisnerCare.Web.Pages.Staff.MedicationOverviewModel
@{
    ViewData["Title"] = "💊 Medicin Oversigt";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1><i class="bi bi-capsule me-2 text-success"></i>Medicin Oversigt</h1>
    <div class="d-flex gap-2">
        <a href="/Medications/Create" class="btn btn-success btn-lg">
            <i class="bi bi-plus-lg me-1"></i>Ny Medicin
        </a>
        <a href="/Dashboard" class="btn btn-secondary">
            <i class="bi bi-arrow-left me-1"></i>Tilbage
        </a>
    </div>
</div>

<div class="row g-4 mb-4">
    <div class="col-md-4">
        <div class="card bg-primary text-white border-0 shadow-sm">
            <div class="card-body text-center">
                <i class="bi bi-capsule display-4 mb-2 opacity-75"></i>
                <h5>Total Medicin</h5>
                <p class="display-5 fw-bold mb-0">@Model.Medications.Count</p>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card bg-success text-white border-0 shadow-sm">
            <div class="card-body text-center">
                <i class="bi bi-check-circle display-4 mb-2 opacity-75"></i>
                <h5>Taget I Dag</h5>
                <p class="display-5 fw-bold mb-0">@Model.Medications.Count(m => m.TakenToday)</p>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card bg-warning text-dark border-0 shadow-sm">
            <div class="card-body text-center">
                <i class="bi bi-hourglass-split display-4 mb-2 opacity-75"></i>
                <h5>Afventer</h5>
                <p class="display-5 fw-bold mb-0">@Model.Medications.Count(m => !m.TakenToday)</p>
            </div>
        </div>
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-header bg-dark text-white">
        <h5 class="mb-0"><i class="bi bi-list me-2"></i>Alle Medicin</h5>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th><i class="bi bi-person me-1"></i>Patient</th>
                        <th><i class="bi bi-capsule me-1"></i>Medicin</th>
                        <th>Dosis</th>
                        <th>Frekvens</th>
                        <th>Status</th>
                        <th>Effekt</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var med in Model.Medications)
                    {
                        <tr>
                            <td class="fw-bold">@med.PatientName</td>
                            <td><span class="badge bg-success">@med.MedicationName</span></td>
                            <td>@med.Dosage</td>
                            <td><i class="bi bi-clock me-1 text-muted"></i>@med.Frequency</td>
                            <td>
                                @if (med.TakenToday)
                                {
                                    <span class="badge bg-success"><i class="bi bi-check-lg me-1"></i>Taget</span>
                                }
                                else
                                {
                                    <span class="badge bg-warning text-dark"><i class="bi bi-hourglass me-1"></i>Afventer</span>
                                }
                            </td>
                            <td>
                                @if (med.Effectiveness.HasValue)
                                {
                                    <span class="badge bg-info">@med.Effectiveness.Value/5 ⭐</span>
                                }
                                else
                                {
                                    <span class="text-muted">-</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>