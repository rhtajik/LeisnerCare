@page
@model LoginModel
@{
    ViewData["Title"] = "Log ind";
}

<div class="row justify-content-center align-items-center min-vh-100">
    <div class="col-md-5 col-lg-4">
        <div class="card shadow-lg border-0">
            <div class="card-header bg-primary text-white text-center py-4">
                <i class="bi bi-heart-pulse-fill display-4 mb-2"></i>
                <h2 class="mb-0">LeisnerCare</h2>
                <p class="mb-0 opacity-75">Parkinson Monitor</p>
            </div>
            <div class="card-body p-4">
                <h4 class="text-center mb-4 text-muted">
                    <i class="bi bi-box-arrow-in-right me-2"></i>Log ind
                </h4>

                <form method="post">
                    <div asp-validation-summary="All" class="alert alert-danger" role="alert"></div>

                    <div class="mb-3">
                        <label asp-for="Input.Email" class="form-label">
                            <i class="bi bi-envelope me-1 text-primary"></i>Email
                        </label>
                        <input asp-for="Input.Email" class="form-control form-control-lg"
                               placeholder="din@email.dk" />
                        <span asp-validation-for="Input.Email" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Input.Password" class="form-label">
                            <i class="bi bi-lock me-1 text-primary"></i>Password
                        </label>
                        <input asp-for="Input.Password" type="password" class="form-control form-control-lg"
                               placeholder="Dit password" />
                        <span asp-validation-for="Input.Password" class="text-danger"></span>
                    </div>

                    <div class="mb-3 form-check">
                        <input asp-for="Input.RememberMe" class="form-check-input" />
                        <label asp-for="Input.RememberMe" class="form-check-label">
                            Husk mig
                        </label>
                    </div>

                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-primary btn-lg">
                            <i class="bi bi-box-arrow-in-right me-2"></i>Log ind
                        </button>
                    </div>
                </form>

                <hr class="my-4" />

                <div class="text-center">
                    <p class="text-muted mb-2">Har du ikke en konto?</p>
                    <a href="/Account/Register" class="btn btn-outline-success">
                        <i class="bi bi-person-plus me-2"></i>Opret konto
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}