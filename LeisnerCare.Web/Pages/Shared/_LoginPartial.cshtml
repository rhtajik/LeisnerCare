@using Microsoft.AspNetCore.Identity
@using LeisnerCare.Core.Entities
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

<ul class="navbar-nav">
@if (SignInManager.IsSignedIn(User))
{
    <li class="nav-item">
        <a class="nav-link text-white" href="#">
            <i class="bi bi-person-circle me-1"></i>@UserManager.GetUserName(User)
        </a>
    </li>
    <li class="nav-item">
        <form class="form-inline" method="post" asp-page="/Account/Logout">
            <button type="submit" class="nav-link btn btn-link text-white">
                <i class="bi bi-box-arrow-right me-1"></i>Log ud
            </button>
        </form>
    </li>
}
else
{
    <li class="nav-item">
        <a class="nav-link text-white" asp-page="/Account/Register">
            <i class="bi bi-person-plus me-1"></i>Opret konto
        </a>
    </li>
    <li class="nav-item">
        <a class="nav-link text-white" asp-page="/Account/Login">
            <i class="bi bi-box-arrow-in-right me-1"></i>Log ind
        </a>
    </li>
}
</ul>